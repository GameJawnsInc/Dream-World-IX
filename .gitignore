# ── FF9 Memoria mod repo ───────────────────────────────────────────────
# Track: our scripts, metadata edits, .hws source, docs, text backups.
# Ignore: the game install, tool clones, large binaries, derived output.

# ── Game install (never commit — it's huge and not ours) ───────────────
# Keep the actual FINAL FANTASY IX folder OUTSIDE this repo. If anything
# game-related lands inside, these catch it:
game/
FINAL FANTASY IX/
**/StreamingAssets/p0data*.bin
**/StreamingAssets/s*data*.bin
**/*.assets
**/*.resource
**/*.resS
**/*.bundle
**/AssetBundles/

# ── Tool clones (keep Memoria / Hades Workshop checkouts separate) ──────
memoria/
Memoria/
hades-workshop/
Hades-Workshop/

# ── Generated campaigns (regenerable via `ff9mapkit import-chain`; member dirs hold ──────
#    game-derived scene/art bytes -- .bgx/.bgi/.eb + layer PNGs -- so never commit) ────────
campaigns/

# ── Binaries & build artifacts (derived, not source) ───────────────────
*.dll
*.exe
*.so
*.dylib
*.pdb
*.zip
*.7z
*.rar
# Compiled battle-script output from Memoria.Compiler (regenerated on build)
**/Scripts/Output/
**/Compiler/*.log

# ── OS / editor noise ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~
.vscode/
.idea/

# ── Bulk Hades Workshop field-script exports ──────────────────────────
# Regenerable from HW via Batch → Export Field Scripts. The 800+ per-field
# .txt files are ~80MB total — too much repo churn for something we can
# regenerate any time. We keep reference/field-manifest.tsv committed for
# fast ID/name lookup; the raw dump lives on disk only.
reference/test2/
reference/all-fields-export/
reference/all-fields-import/

# ── NOTE ───────────────────────────────────────────────────────────────
# backups/ IS tracked on purpose (small text safety net). If you ever back
# up a binary there, add an explicit ignore for it below:
# backups/*.bin
# Binary DLL/exe backups (e.g. Assembly-CSharp.dll.<label>.<timestamp>) — big &
# regenerable from memoria-patches/ + a rebuild, so keep them on disk only.
backups/*.dll.*
backups/*.exe.*
mod/custom-room-01/npc-script-new/**/atlas.png
tools/*.regen.bgx
__pycache__/
blendertest/

# calibration / bounds-test build output (derived, regenerable from tools/build_*.py)
tools/*_out/

# Binary backups under backups/ (regenerable; keep on disk only, like the .dll/.exe rule)
backups/*.eb.bytes.*
backups/*.bgi.bytes.*
backups/*.bgx.*
backups/*.png.*
backups/pre-reclone-*/
# Transient build/scratch logs under backups/ (regenerable; not the intentional text safety-net)
backups/*.log

# deploy_field.py's transient pre-overwrite safety nets (the test-slot DictionaryPatch/.mes it
# snapshots on every deploy). Distinct from intentional manual backups/<file>.<timestamp> -- these
# pile up fast and only ever protect the throwaway test slot. On disk only.
backups/*.preDEPLOY.*
backups/*.preSCROLL.*
# deploy_campaign.py's set-wide pre-deploy mod-folder snapshots (full game-folder copies, e.g.
# backups/FF9CustomMap-ow.pre-ICE_CAVERN.<ts>/). Like the per-deploy snapshots above: on disk only.
backups/*.pre-*/

# deploy_battle.py's transient pre-overwrite safety nets (the DictionaryPatch/BattlePatch snapshots +
# the battle_predeploy.<stamp>/ dirs holding copies of every overwritten file). The predeploy dirs can
# contain SE-derived scene assets (forked raw16/raw17/eb/mes) -- NEVER commit them. On disk only.
backups/*.preBATTLE.*
backups/battle_predeploy.*/

# Per-worktree deploy target (mod folder + slot id). Each worktree pins its own so they never share a
# mod folder / DictionaryPatch and can't clobber each other's registrations. On disk only.
.ff9deploy.toml

# Scratch dir for ATE test forks (verbatim-extracted real-field .eb/.mes/atlas -- SE-derived; on disk only).
_scratch_ate/

# Battle-map geometry + minted-scene assets forked from the install by `ff9mapkit battle-import`
# (SE-derived; regenerate any time). Same zero-SE-bytes posture as the field *.eb.bytes/*.bgx — never commit.
*.fbx
*bbg*_geom.json
# tier-c MINT forked scene assets (the `scene/` dir battle-import --fork-scene writes: raw16/raw17 + eb/mes)
*.raw16.bytes
*.raw17.bytes
# bare raw16/raw17 donor extracts (battle-tuning recon/dev scratch -- SE game data, never commit)
*.raw16
*.raw17
# battle-tuning in-game-test scratch (forked SE scene assets + the trigger field copy) -- on disk only
/battle_tests/
**/scene/eb/*.eb.bytes
**/scene/mes/*.mes

# Field-import verbatim object-entry sidecars: `ff9mapkit import` writes <name>.objectN.bin = a real
# field object's .eb entry bytes, grafted at build (faithful object carry). SE-derived -- never commit
# (same zero-SE-bytes posture as the field *.eb.bytes/*.bgx art). Regenerable from the install any time.
*.object*.bin
# Player-function graft sidecars (`ff9mapkit import --graft-player-funcs` writes <name>.playerfuncN.bin = a
# real donor player gesture function's bytes, grafted onto the fork player). SE-derived -- never commit.
*.playerfunc*.bin

# Dialogue read out of the game (`ff9mapkit dialogue-import --out FILE.dialogue.json`): a VIEW of real FF9
# text -- SE-derived, regenerable from the install. Use the `.dialogue.json` suffix so it's never committed;
# only author-written dialogue (in a field.toml) belongs in the repo.
*.dialogue.json
# Faithful text-carry sidecars (`ff9mapkit import --carry-text` writes <name>.carrytext.json = the donor
# field's referenced .mes strings, per language + the donor->carried txid map, shipped VERBATIM so a forked
# interaction shows the real words). SE-derived -- never commit (same posture as the object/player sidecars).
*.carrytext.json
# `imported/` output dir AT ANY DEPTH (the FFIX Import GUI default + any `import --out imported/...`, incl.
# a cwd-relative one under ff9mapkit/). A fork's assets (atlas.png / scene.bgs.bytes / mapconfig.bytes /
# camera.bgx / *.object*.bin) are SE-DERIVED game bytes -- the whole dir must never be committed (the
# zero-SE-bytes provenance gate). Unanchored so it catches imported/ wherever a tool/agent writes it.
imported/

# Blender working/test projects (user art + exports)
ff9mapkit/blender/debug_proj/

# release: track the packaged mod source, not the built zip
release/*.zip

# pip editable-install metadata
*.egg-info/
build/

# dev tooling cache (model->field-usage index; game-derived, regenerable via --build)
tools/model_field_usage.json

# story-flag research: the full census JSON is large (~1 MB) and regenerable from the install
# (research/flag_census.py). Keep the human-readable digest/report/catalog + the tools tracked.
research/flag_census.json
# UNDERSTAND-layer pass: generated outputs of research/gen_understand_layer.py (regenerable). Track the
# generator + the STORY_FLAGS.md §8 write-up, ignore the derived JSON + the verification-input scratch.
research/understand_layer.json
research/understand_candidate.md

_private_memoria_archive/
tools/prop_poses.json
tools/attach_poses.json

# Tier-c probe auto-generated reverts (absolute install paths; regenerated by the probes)
tools/_tierc_*.py
/_savescratch/

# Provenance: SE-derived dev artifacts removed (sessions 1-9 scratch); never re-commit.
# The kit's OWN content lives in release/FF9CustomMap + tests/fixtures/hut_* (kept).
/mod/
/reference/bgx-samples/
/tools/room0[0-9]_out/
backups/*evt_alex*
backups/*ROOM01_BASE*
backups/CUSTOM_ROOM_01*
backups/EVT_CUSTOM_FIELD_*
backups/field70-warp*
backups/*prima-vista*.txt
backups/*opening-for-fmv*.txt

# save-Moogle director sidecar (SE-derived: the donor field entry-0 tag-1 logic)
ff9mapkit/**/*.savemoogle_director.bin
*.savemoogle_director.bin
ff9mapkit/docs/EDITABLE_CAMPAIGN_ART.md
backups/

# throwaway proof/scratch files (not committed)
scratch/
