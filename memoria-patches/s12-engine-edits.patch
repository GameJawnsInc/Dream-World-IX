+        // General_FieldEntrance (gEventGlobal[2..3]); same value the engine reads at EventEngine.cs:657.
+        FF9StateSystem.EventState.FieldEntrance = 204;
         FF9StateSystem.Settings.time = 0.0;
         this._encountTimer = Configuration.Battle.EncounterInitial;
