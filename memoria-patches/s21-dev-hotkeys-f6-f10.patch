     public override void HonoLateUpdate()
     {
+        // [ff9mapkit dev] F6 = reload the current field. Re-runs Main_Init (replays once=false
+        // cutscenes, re-creates NPCs) and frees you from any cutscene softlock -- fast content
+        // iteration without restarting the game. Replicates the Field() opcode's reload path
+        // (SetNextMap + nextMode=1 + change-scene attr). Dev engine only; not part of the shipped mod.
+        if (UnityEngine.Input.GetKeyDown(UnityEngine.KeyCode.F6))
+        {
+            PersistenSingleton<EventEngine>.Instance.SetNextMap(FF9StateSystem.Common.FF9.fldMapNo);
+            FF9StateSystem.Field.FF9Field.loc.map.nextMode = 1;
+            PersistenSingleton<FF9StateSystem>.Instance.attr |= 8u;
+            return;
+        }
+        // [ff9mapkit dev] F10 = reset event/save state, then reload the current field (like F6).
+        // Zeroes gEventGlobal (the 2048-byte save-backed story/once flag array) + Memoria's persistent
+        // script stores, so once-gated content (levers, chests, cutscenes, requires_flag gates) re-arms
+        // and flag-gated logic can be re-tested WITHOUT a New Game. Inventory/gil/party are untouched.
+        // Mirrors EventEngine.NewGame()'s flag reset. Dev engine only; not part of the shipped mod.
+        if (UnityEngine.Input.GetKeyDown(UnityEngine.KeyCode.F10))
+        {
+            System.Array.Clear(FF9StateSystem.EventState.gEventGlobal, 0, FF9StateSystem.EventState.gEventGlobal.Length);
+            FF9StateSystem.EventState.gScriptVector.Clear();
+            FF9StateSystem.EventState.gScriptDictionary.Clear();
+            PersistenSingleton<EventEngine>.Instance.SetNextMap(FF9StateSystem.Common.FF9.fldMapNo);
+            FF9StateSystem.Field.FF9Field.loc.map.nextMode = 1;
+            PersistenSingleton<FF9StateSystem>.Instance.attr |= 8u;
+            return;
+        }
         this.SceneService2DScroll();
         this.SceneService3DScroll();
