diff --git a/Assembly-CSharp/Global/UI/UIKey/UIKeyTrigger.cs b/Assembly-CSharp/Global/UI/UIKey/UIKeyTrigger.cs
index b8091950..136edc96 100644
--- a/Assembly-CSharp/Global/UI/UIKey/UIKeyTrigger.cs
+++ b/Assembly-CSharp/Global/UI/UIKey/UIKeyTrigger.cs
@@ -155,6 +155,34 @@ public class UIKeyTrigger : MonoBehaviour
             AccelerateKeyNavigation();
             if (HandleMenuControlKeyPressCustomInput())
                 return;
+            // [ff9mapkit dev] F6 = reload the current field; F10 = reset event/save state + reload.
+            // Read here in UIKeyTrigger.Update (runs every render frame, reliable input) instead of
+            // FieldMap.HonoLateUpdate, which runs on the ~30fps logical tick and frequently MISSES the
+            // single-render-frame GetKeyDown (the "dead press" + booster error SFX). F6 reloads the
+            // field (re-runs Main_Init: replays once=false cutscenes, re-creates NPCs, escapes a
+            // cutscene softlock). F10 additionally zeroes gEventGlobal (the save-backed story/once flag
+            // array) + Memoria's persistent script stores so once-gated content (levers, chests,
+            // cutscenes, requires_flag gates) re-arms WITHOUT a New Game -- inventory/gil/party
+            // untouched. Intercepted before HandleBoosterButton so F6 no longer also fires the
+            // LvMax-disabled SFX. Dev engine only; not part of the shipped mod.
+            if (PersistenSingleton<UIManager>.Instance.State == UIManager.UIState.FieldHUD)
+            {
+                Boolean ff9mkReload = UnityXInput.Input.GetKeyDown(KeyCode.F6);
+                Boolean ff9mkReset = UnityXInput.Input.GetKeyDown(KeyCode.F10);
+                if (ff9mkReload || ff9mkReset)
+                {
+                    if (ff9mkReset)
+                    {
+                        System.Array.Clear(FF9StateSystem.EventState.gEventGlobal, 0, FF9StateSystem.EventState.gEventGlobal.Length);
+                        FF9StateSystem.EventState.gScriptVector.Clear();
+                        FF9StateSystem.EventState.gScriptDictionary.Clear();
+                    }
+                    PersistenSingleton<EventEngine>.Instance.SetNextMap(FF9StateSystem.Common.FF9.fldMapNo);
+                    FF9StateSystem.Field.FF9Field.loc.map.nextMode = 1;
+                    PersistenSingleton<FF9StateSystem>.Instance.attr |= 8u;
+                    return;
+                }
+            }
             HandleBoosterButton();
             HandleDialogControlKeyPressCustomInput();
         }
