+        // [ff9mapkit] ForkDonorPatch.txt: one mapping per line, "<forkId> <donorRealId>" (# / ; comment ok).
+        private static void PatchForkDonors(String[] code)
+        {
+            foreach (String line in code)
+            {
+                String s = line.Trim();
+                if (s.Length == 0 || s[0] == '#' || s[0] == ';')
+                    continue;
+                String[] parts = s.Split(DataPatchers.SpaceSeparators, StringSplitOptions.RemoveEmptyEntries);
+                if (parts.Length >= 2 && Int32.TryParse(parts[0], out Int32 fork) && Int32.TryParse(parts[1], out Int32 donor))
+                {
+                    ForkDonorMap[fork] = donor;
+                    ForkSiblingMap[donor] = (ForkSiblingMap.TryGetValue(donor, out Int32 prev) && prev != fork) ? -1 : fork;
+                }
+            }
+        }
