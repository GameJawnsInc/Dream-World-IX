+        // Populated from each mod folder's ForkDonorPatch.txt (low->high; higher folders override).
+        private static readonly Dictionary<Int32, Int32> ForkDonorMap = new Dictionary<Int32, Int32>();
+        // reverse of ForkDonorMap (donor real id -> fork id); -1 marks an ambiguous donor (forked twice -> never remap).
