+
+        // The donor real field's FBG NAME for a FORK field's FBG name, else `name` unchanged. The name-space
+        // analogue of EffectiveFieldId, for the NAME-string-keyed gates the id-based wrap can't reach: a fork's
+        // deployed FBG name differs from the donor's, so a name-keyed dict lookup or a hardcoded mapName == "FBG_"
+        // compare misses the donor's tuned entry. Examples it restores: FieldMapExtraOffset/FieldMapSPSExtraOffset
+        // overlay z-offsets (e.g. field 53's overlay-29 dz=-100 that occludes a character falling into a hole),
+        // the Iifa minigame player-control unlock, the Iifa rain offset, the Oeilvert star-display shader. Resolves
+        // by the PASSED NAME (not the current fldMapNo) so it is correct even at cross-field call sites like the SPS
+        // ChangeFieldOrigin: fork name -> fork id (reverse of the global id->FBG-name table) -> EffectiveFieldId ->
+        // donor name. Identity for real (non-forked) fields. [ff9mapkit fork-fidelity]
+        public static String EffectiveFieldName(String name)
+        {
+            if (String.IsNullOrEmpty(name))
+                return name;
+            Int32 count = EventEngineUtils.eventIDToFBGID.Count;
+            if (FBGNameToId == null || FBGNameToIdBuiltForCount != count) // built once after the forks register; rebuilt only if the table grows
+            {
+                FBGNameToId = new Dictionary<String, Int32>(count);
+                foreach (KeyValuePair<Int32, String> kv in EventEngineUtils.eventIDToFBGID)
+                    FBGNameToId[kv.Value] = kv.Key;
+                FBGNameToIdBuiltForCount = count;
+            }
+            if (FBGNameToId.TryGetValue(name, out Int32 id))
+            {
+                Int32 donor = EffectiveFieldId(id);
+                if (donor != id && EventEngineUtils.eventIDToFBGID.TryGetValue(donor, out String donorName))
+                    return donorName;
+            }
+            return name;
+        }
+        private static Dictionary<String, Int32> FBGNameToId;
+        private static Int32 FBGNameToIdBuiltForCount = -1;
 
