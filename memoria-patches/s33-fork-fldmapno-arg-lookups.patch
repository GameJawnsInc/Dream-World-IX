+        // [ff9mapkit] The menu/title LOCATION name for a field id, with fork-fidelity + custom-title support:
+        // loc_name.mes is keyed by the REAL field id, so a custom/forked id (>=4000) has no entry and shows BLANK.
+        // Try the field's OWN id first -- a mod can patch loc_name.mes to AUTHOR a custom field's title, or to
+        // OVERRIDE a fork's -- and only when that is empty fall back to the fork's DONOR id (a plain fork then
+        // inherits the donor's location name). Identity for a real field (its own id hits). Used by EventEngine
+        // (mapNameStr) and MainMenuUI (the in-field menu LOCATION label, which looks up by field id directly).
+        public static String FieldLocationName(Int32 fldMapNo)
+        {
+            if (Memoria.DataPatchers.TryGetCustomLocationName(fldMapNo, out String custom) && !String.IsNullOrEmpty(custom))
+                return custom; // an authored "LocationName <id> <title>" (custom field title / fork override)
+            String result = LocationName(fldMapNo);
+            if (String.IsNullOrEmpty(result))
+            {
+                Int32 donor = Memoria.DataPatchers.EffectiveFieldId(fldMapNo);
+                if (donor != fldMapNo)
+                    result = LocationName(donor);
+            }
+            return result;
+        }
